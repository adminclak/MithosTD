# Copie este arquivo para ".env" (mesma pasta) e preencha com a sua chave real.
# O .env e ignorado pelo git — a chave NUNCA vai para o repositorio.
# O tools/gen_api.py le este arquivo automaticamente.

# Chave da fal.ai (Dashboard -> Keys). Formato: "xxxxxxxx:yyyyyyyy"
FAL_KEY=

# (opcional) modelo a usar. Padrao: fal-ai/flux/dev
# FAL_MODEL=fal-ai/flux/dev

# Chave da API do Meshy (Meshy PRO -> menu API -> Create API key). Formato: "msy_..."
# Lida por tools/meshy_gen.py automaticamente.
MESHY_API_KEY=
